# ── Supabase ──────────────────────────────────────────────────────────────────
# Obténlos en: https://supabase.com/dashboard/project/<tu-proyecto>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de servicio (solo servidor, NUNCA exponer al cliente)
# Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Aplicación ────────────────────────────────────────────────────────────────
# UUID del cliente SULICOR generado por el script SQL semilla
# Cópialo de la tabla `clients` tras ejecutar el SQL de migración
CLIENT_ID=00000000-0000-0000-0000-000000000001

# ── Integración Excel / SharePoint (opcional) ─────────────────────────────────
# Si se configura, cada consecutivo generado se registra automáticamente en el
# archivo Excel de SharePoint indicado y se abre en una nueva pestaña.
#
# Cómo obtener las credenciales de Azure AD:
#   1. Portal Azure → App registrations → New registration
#   2. Crear un Client Secret en "Certificates & secrets"
#   3. Agregar permiso de API: Microsoft Graph → Files.ReadWrite.All (Application)
#   4. Conceder "Admin consent" al permiso
#   5. Copiar Tenant ID (Directory ID), Application (Client) ID y el secret
MICROSOFT_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_SECRET=tu-client-secret-aqui

# URL de compartir de SharePoint (el enlace "Copiar vínculo" del archivo Excel,
# debe incluir el token ?e=... al final)
EXCEL_SHAREPOINT_URL=https://tu-empresa.sharepoint.com/:x:/g/personal/.../IQ...?e=XXXXX

# ── Alternativa más estable: IDs directos (recomendado para producción) ────────
# Si configuras AMBOS valores, el sistema los usa directamente y no intenta
# resolver la URL (más robusto, no depende del formato del enlace).
#
# Cómo obtenerlos con Graph Explorer (https://aka.ms/ge):
#   1. Inicia sesión con la cuenta dueña del archivo
#   2. Ejecuta: GET https://graph.microsoft.com/v1.0/me/drive/root/children
#      Busca el archivo Excel en los resultados y copia su "id"
#   3. El "parentReference.driveId" del mismo resultado es el EXCEL_DRIVE_ID
#
# EXCEL_DRIVE_ID=b!xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EXCEL_ITEM_ID=01XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Nombre de la hoja de trabajo (si se omite, usa la primera hoja del libro)
# EXCEL_WORKSHEET_NAME=Hoja1

# Columna donde escribir los consecutivos (por defecto: A)
# EXCEL_COLUMN=A
